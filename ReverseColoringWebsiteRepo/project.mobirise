          "_name": "form01",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"form1\" group=\"Form\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\" plugins=\"formstyler, datepicker\">\n\t<mbr-parameters>\n\t\t<header>Size</header>\n\t\t<input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n\t\t<input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n\t\t<input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n\t\t<input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n\t\t<header>Show/Hide</header>\n\t\t<input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n\t\t<header>Background</header>\n\t\t<input type=\"color\" name=\"bgColor\" title=\"Color\" value=\"#ffffff\" selected>\n\t\t<input type=\"hidden\" name=\"usedRecaptcha\" value=\"false\">\n\t</mbr-parameters>\n\n\t<div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n\t<div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n\t\t<div class=\"row content-wrapper justify-content-center\">\n<div class=\"dragArea row\">\n<div class=\"col-lg-12 col-md-12 col-sm-12\">\n<h5 mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" class=\"mbr-section-title mbr-fonts-style mb-5\">Send me weekly designs.</h5>\n                    <iframe src=\"https://reversecoloring.substack.com/embed\" width=\"480\" height=\"320\" style=\"border:0px solid #EEE; background:#260a30;\" frameborder=\"0\" scrolling=\"no\"></iframe>\n</div>\n</div>\n\t\t</div>\n\t</div>\n</section>",
          "_cid": "tIsokmLLOC",
          "_anchor": "sign-up",
          "_PHPplaceholders": [],
          "_JSplaceholders": [],
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".mbr-section-title": {
              "text-align": "center"
            },
            ".mbr-section-subtitle": {
              "text-align": "center"
            }
          },
          "_name": "list02",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"content4\" group=\"Content\" data-bg-video=\"{{bg.type == 'video'&&bg.value.url}}\" mbr-class=\"{'mbr-fullscreen': fullScreen, 'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"6\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"6\" condition=\"fullScreen == false\">\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"12\" step=\"1\" value=\"10\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#bcef9b\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\">\n    </div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-lg-{{textWidth}}\">\n                <div class=\"title col-md-12 mb-5\">\n                    <h3 class=\"mbr-section-title mbr-fonts-style\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\">\n                        <b>FAQs</b></h3>\n                    <h4 class=\"mbr-section-subtitle mbr-fonts-style mb-0 mt-4\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-7\">\n                        List main features of your project in this block.\n                    </h4>\n                </div>\n                <div class=\"item features-without-image col-12\">\n                    <div class=\"item-wrapper\">\n                        <div class=\"card-box align-left\">\n                            <h5 class=\"card-title mbr-fonts-style mb-3\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\">\n                                <b>What is Reverse Coloring?</b></h5>\n                            <p class=\"card-text mbr-fonts-style mb-5\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">\n                                Reverse coloring is a unique twist on traditional coloring books. Instead of starting with white pages featuring black outlines to fill in with color, reverse coloring presents pre-colored pages. <br><br>These vibrant backgrounds set the stage for you to add your own patterns, details, and outlines. The process encourages a different kind of creativity, where you define the shapes and bring structure to a colorful canvas, effectively \"coloring\" with lines and forms instead of different hues. <br><br>It's a creative challenge that flips the usual coloring approach, pushing the boundaries of imagination and artistic expression.\n                            </p>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"item features-without-image col-12\">\n                    <div class=\"item-wrapper\">\n                        <div class=\"card-box align-left\">\n                            <h5 class=\"card-title mbr-fonts-style mb-3\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\">\n                                <b>How Do I Start?</b></h5>\n                            <p class=\"card-text mbr-fonts-style mb-5\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\"><b>Choose Your Page: </b>Select a pre-colored page from our collection that inspires you. Look for colors and gradients that spark your imagination. Print it out using your computer or mobile device.<br><br><b>Gather Your Tools:</b> While our pages have the color, you’ll need pens, pencils, markers, or any drawing tool you prefer for adding lines and details.<br><br><b>Add Your Lines:</b> Begin drawing directly on your reverse coloring page. You can outline areas to define shapes or add patterns and textures.<br><br><b>Embrace Imperfections:</b> Don't worry about making mistakes. Every line adds character and makes your design uniquely yours.<br><br><b>Enjoy the Process:</b> Remember, the goal is to relax and enjoy the creative journey. There's no right or wrong way to do it! Don't worry about making mistakes. Every line adds character and makes your design uniquely yours.<br></p>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"item features-without-image col-12\">\n                    <div class=\"item-wrapper\">\n                        <div class=\"card-box align-left\">\n                            <h5 class=\"card-title mbr-fonts-style mb-3\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\">\n                                <b>Is It Free?</b></h5>\n                            <p class=\"card-text mbr-fonts-style mb-5\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">Yes, the designs above are free.</p>\n                        </div>\n                    </div>\n                </div><div class=\"item features-without-image col-12\">\n                    <div class=\"item-wrapper\">\n                        <div class=\"card-box align-left\">\n                            <h5 class=\"card-title mbr-fonts-style mb-3\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\">\n                                <b>What do I get when I sign-up for Weekly Designs?</b></h5>\n                            <p class=\"card-text mbr-fonts-style mb-5\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\"><br>When you sign up for Weekly Designs on FreeReverseColoringBook.com, you receive a curated selection of fresh reverse coloring pages every week. Each design is crafted to ignite your creativity and provide a diverse range of themes and color palettes suitable for all skill levels.<br></p>\n                        </div>\n                    </div>\n                </div><div class=\"item features-without-image col-12\">\n                    <div class=\"item-wrapper\">\n                        <div class=\"card-box align-left\">\n                            <h5 class=\"card-title mbr-fonts-style mb-3\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\"><b>What are the best pens for Reverse Coloring?</b></h5>\n                            <p class=\"card-text mbr-fonts-style mb-5\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">For a Reverse Coloring, where you're drawing lines or adding details to pre-colored pages, the best pens would ideally have qualities that allow for precision, a variety of line widths, and vibrant ink that stands out on colored backgrounds. Here's a selection of pens that are highly recommended for such tasks:<br><br><b>Micron Pens:</b> These pens are celebrated for their precision and archival-quality ink. They come in various sizes, allowing for fine detail work as well as bolder lines. The ink is also waterproof and fade-resistant, making it a fantastic choice for detailed work on any page color.<br><br><b>Faber-Castell Pitt Artist Pens:</b> Known for their high-quality pigmented India ink, these pens offer excellent opacity and smooth application. They’re great for overlaying lines on colored backgrounds because the ink is very pigmented, ensuring your lines pop against the color.<br><br><b>Uni-ball Signo Gel Pens:</b> These gel pens are particularly good for their range of colors, including white, which is excellent for highlighting or drawing on dark backgrounds. The ink flows smoothly, allowing for nice, crisp lines that stand out.<br><br><b>Sakura Gelly Roll Pens:</b> These pens are ideal for adding decorative touches or highlights. They come in various colors, including white, metallic, and glitter, which can add a unique dimension to your artwork.<br><br><b>Staedtler Triplus Fineliners:</b> These are fine-tipped pens perfect for detail work, with water-based ink that doesn’t bleed through pages. They offer a wide range of colors for different artistic expressions.<br><br><b>Stabilo Point 88 Fineliner Pens:</b> Known for their fine tips and vibrant ink, these pens are great for precision and adding colorful details that stand out.<br><br><b>Pilot FriXion Pens:</b> If you're nervous about making permanent marks, these erasable gel pens can be a good choice. They allow for corrections and adjustments as you define your artwork.<br></p>\n                        </div>\n                    </div>\n                </div><div class=\"item features-without-image col-12\">\n                    <div class=\"item-wrapper\">\n                        <div class=\"card-box align-left\">\n                            <h5 class=\"card-title mbr-fonts-style mb-3\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\"><b>What happens when adults do coloring books?</b></h5>\n                            <p class=\"card-text mbr-fonts-style mb-5\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">Engaging in coloring books offers adults a myriad of benefits that encompass mental, emotional, and cognitive health. Here’s a summary:<br><br><b>Mental Health:</b> Coloring can significantly reduce stress and anxiety, fostering a state of mindfulness and presence. It acts as a form of meditation, redirecting focus from stressors and improving mood and concentration.<br><br><b>Creativity and Cognitive Skills:</b> It encourages creativity within structured lines, offering a unique outlet for expressing imagination. The activity also helps in enhancing fine motor skills and hand-eye coordination.<br><br><b>Social and Emotional Well-being:</b> Adult coloring cultivates a sense of community through sharing artwork and experiences, reducing feelings of isolation. It serves as a therapeutic outlet for non-verbal expression of emotions and can be particularly effective in managing anxiety.<br><br><b>Physical Benefits:</b> The relaxation induced by coloring has been linked to lower blood pressure, highlighting its physical health benefits.<br><br><b>Accessibility:</b> Coloring is an easily accessible hobby that doesn’t require special skills or expensive materials, making it a versatile option for stress relief and creative expression at any time and place.<br></p>\n                        </div>\n                    </div>\n                </div><div class=\"item features-without-image col-12\">\n                    <div class=\"item-wrapper\">\n                        <div class=\"card-box align-left\">\n                            <h5 class=\"card-title mbr-fonts-style mb-3\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\"><b>How long does it take to complete a reverse coloring page?</b></h5>\n                            <p class=\"card-text mbr-fonts-style mb-5\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\"><br>The time it takes to complete a reverse coloring page can vary widely depending on several factors, including the complexity of the design, the coloring materials used (such as watercolors, markers, or colored pencils), the level of detail desired by the colorist, and the individual's coloring speed and skill level. For simpler designs, a colorist might spend an hour or less, while more intricate designs could take several hours or even spread over multiple coloring sessions.<br><br>For beginners, a less detailed page might take 1-3 hours to color, as they might be exploring techniques and color combinations. More experienced colorists or those working on highly detailed pages might spend 5-10 hours or more to achieve the depth and detail they desire.<br><br>Reverse coloring pages, which often involve coloring the spaces around traditional line art to create unique, negative-space effects, can add an extra layer of complexity and might require more time than traditional coloring pages, especially if aiming for smooth color gradients or detailed shading.<br></p>\n                        </div>\n                    </div>\n                </div><div class=\"item features-without-image col-12\">\n                    <div class=\"item-wrapper\">\n                        <div class=\"card-box align-left\">\n                            <h5 class=\"card-title mbr-fonts-style mb-3\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .iconfont-wrapper\"><b>I have feedback / question. How should I contact?</b></h5>\n                            <p class=\"card-text mbr-fonts-style mb-5\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">Please contact us at email@FreeReverseColoring.com</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "u8IUt7qcXz",
          "_anchor": "faqs",
          "_PHPplaceholders": [],
          "_JSplaceholders": [],
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".container": {
              "@media (max-width: 991px)": {
                "padding": "0 16px"
              },
              "@media (max-width: 767px)": {
                "padding": "0 12px"
              }
            },
            ".social-row": {
              "display": "flex",
              "justify-content": "center",
              "align-items": "center",
              "flex-wrap": "wrap",
              ".soc-item": {
                "margin": "8px",
                "a": {
                  "&:hover, &:focus": {
                    ".mbr-iconfont": {
                      "background-color": "@active"
                    }
                  },
                  ".mbr-iconfont": {
                    "width": "72px",
                    "height": "72px",
                    "display": "flex",
                    "align-items": "center",
                    "justify-content": "center",
                    "border-radius": "100%",
                    "font-size": "32px",
                    "background-color": "@iconBg",
                    "color": "@icon",
                    "transition": "all 0.3s ease-in-out"
                  }
                }
              }
            },
            ".row-links": {
              "width": "100%",
              "justify-content": "center"
            },
            ".header-menu": {
              "list-style": "none",
              "display": "flex",
              "justify-content": "center",
              "flex-wrap": "wrap",
              "padding": "0",
